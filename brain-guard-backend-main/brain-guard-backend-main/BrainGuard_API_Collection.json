{
  "info": {
    "name": "BrainGuard API v1 - Clean Architecture",
    "description": "Postman Collection divided into highly modular folders matching the clean backend architecture.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://brainguard.devawy.com/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "YOUR_AUTH_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Authentication",
      "description": "Endpoints related to user registration, login, OTP, and session management.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"role\": \"patient\",\n    \"full_name\": \"John Doe\",\n    \"email\": \"patient2@example.com\",\n    \"password\": \"password\",\n    \"password_confirmation\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/register", "host": [ "{{base_url}}" ], "path": [ "auth", "register" ] }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"patient@example.com\",\n    \"password\": \"password\",\n    \"fcm_token\": \"optional_device_token\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": [ "{{base_url}}" ], "path": [ "auth", "login" ] }
          }
        },
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"patient@example.com\",\n    \"type\": \"registration\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/otp/send", "host": [ "{{base_url}}" ], "path": [ "auth", "otp", "send" ] }
          }
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"patient@example.com\",\n    \"otp\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/otp/verify", "host": [ "{{base_url}}" ], "path": [ "auth", "otp", "verify" ] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"patient@example.com\",\n    \"password\": \"newpassword123\",\n    \"password_confirmation\": \"newpassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/password/reset", "host": [ "{{base_url}}" ], "path": [ "auth", "password", "reset" ] }
          }
        },
        {
          "name": "Get Profile (Me)",
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/me", "host": [ "{{base_url}}" ], "path": [ "auth", "me" ] }
          }
        },
        {
          "name": "Update FCM Token",
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"fcm_token\": \"new_token_from_flutter\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/auth/fcm-token", "host": [ "{{base_url}}" ], "path": [ "auth", "fcm-token" ] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "bearer", "bearer": [ { "key": "token", "value": "{{token}}", "type": "string" } ] },
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/auth/logout", "host": [ "{{base_url}}" ], "path": [ "auth", "logout" ] }
          }
        }
      ]
    },
